# Public domain name this server is reachable at (through the Caddy reverse proxy)
PUBLIC_HOSTNAME=ai.yourdomain.com

# Twilio credentials (used to validate/sign the media stream)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=

# Deepgram (speech-to-text and text-to-speech)
DEEPGRAM_API_KEY=
DEEPGRAM_VOICE=aura-asteria-en

# Any OpenAI-compatible LLM provider (DeepSeek, Groq, OpenAI, etc.)
PROVIDER_API_KEY=
PROVIDER_BASE_URL=https://api.deepseek.com/v1
PROVIDER_MODEL=deepseek-chat

# Optional: override the receptionist's system prompt
SYSTEM_PROMPT=You are a professional business receptionist. Answer questions concisely.
